# Backend API URL
VITE_SUMMARIZE_API_URL=http://localhost:8000

# Optional: API Key if your backend requires it
# VITE_SUMMARIZE_API_KEY=your-api-key-here

# Development: Use mock data for admin features when backend is not ready
# Set to 'true' to enable mock data, remove or set to 'false' to use real API
# VITE_USE_MOCK_ADMIN=true
